\makeatletter
\def\@maketitle{%
  \vbox{\hsize\textwidth
    \centering
    % \toptitlebar
    {\LARGE\bfseries \@title\par}
    % \bottomtitlebar
    \vspace{-0.3cm}
    \begin{quote}\rule{\z@}{6pt}%
      {\centering\par{\@author}\par}
    \end{quote}%
    \vskip 0.3in minus 0.1in
  }%
  \begin{center}
  \vspace{-1cm}
  \end{center}
  \vspace{-20pt}
  \thispagestyle{firstpage}
}

